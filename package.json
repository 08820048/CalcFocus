{
	"name": "fluxlocus-workspace",
	"private": true,
	"packageManager": "pnpm@10.17.1",
	"scripts": {
		"tauri": "pnpm --filter @fluxlocus/desktop tauri",
		"dev": "turbo run dev --filter=@fluxlocus/desktop",
		"dev:prod": "pnpm --filter @fluxlocus/desktop dev:prod",
		"build": "turbo run build --filter=@fluxlocus/desktop",
		"build:dev": "pnpm --filter @fluxlocus/desktop build:dev",
		"build:sidecars": "pnpm --filter @fluxlocus/desktop build:sidecars",
		"build:icons": "pnpm --filter @fluxlocus/desktop build:icons",
		"build:mac": "pnpm --filter @fluxlocus/desktop build:mac",
		"build:win": "pnpm --filter @fluxlocus/desktop build:win",
		"build:linux": "pnpm --filter @fluxlocus/desktop build:linux",
		"lint": "turbo run lint",
		"lint:fix": "pnpm --filter @fluxlocus/desktop lint:fix",
		"format": "pnpm --filter @fluxlocus/desktop format",
		"preview": "pnpm --filter @fluxlocus/desktop preview",
		"release:setup-macos-signing": "zsh scripts/setup-github-macos-signing.zsh",
		"release:dispatch": "node scripts/dispatch-release-build.mjs",
		"release:patch": "node scripts/dispatch-release-build.mjs --release-type patch",
		"release:minor": "node scripts/dispatch-release-build.mjs --release-type minor",
		"release:major": "node scripts/dispatch-release-build.mjs --release-type major",
		"i18n:check": "turbo run i18n:check",
		"test": "turbo run test",
		"test:watch": "pnpm --filter @fluxlocus/desktop test:watch"
	},
	"devDependencies": {
		"turbo": "^2.8.20"
	}
}
